# Variables d'environnement du projet Varde.
#
# Copier ce fichier vers .env.local et renseigner les valeurs. Ne pas
# committer .env.local. Toute variable manquante pour un composant qui
# en dépend fait échouer son démarrage avec un message explicite.
#
# Lecture :
# - `apps/server` : `node --env-file=.env.local dist/index.js`
#   (le bin lit process.env, voir apps/server/src/bin.ts).
# - `apps/dashboard` : Next.js charge automatiquement `.env.local`
#   depuis `apps/dashboard/` — placer le fichier là (ou en
#   symlink vers le `.env.local` de la racine).

# Environnement et logs
VARDE_ENV=development
VARDE_LOG_LEVEL=debug

# Discord (application créée dans le Developer Portal).
# Voir CONTRIBUTING.md, section "Créer une application Discord de test".
# Le token bot est utilisé par apps/server côté gateway (câblage
# discord.js à venir — non encore consommé en V1 d'apps/server).
VARDE_DISCORD_TOKEN=
VARDE_DISCORD_CLIENT_ID=
VARDE_DISCORD_CLIENT_SECRET=

# Dashboard (base URL utilisée côté OAuth redirect)
VARDE_DASHBOARD_URL=http://localhost:3000

# Secret de session HS256 partagé par Auth.js côté dashboard et par
# le JWT authenticator côté API (ADR 0006). ≥ 32 octets aléatoires.
# Générer avec : openssl rand -base64 32
VARDE_AUTH_SECRET=

# URL de l'API Fastify consommée par le dashboard côté server
# component (forward du cookie). Default cohérent avec le port Fastify.
VARDE_API_URL=http://localhost:4000

# Port et host HTTP exposés par apps/server (Fastify).
VARDE_API_PORT=4000
VARDE_API_HOST=127.0.0.1

# PostgreSQL
VARDE_DATABASE_URL=postgres://varde:varde@localhost:5432/varde
VARDE_POSTGRES_PORT=5432
VARDE_POSTGRES_USER=varde
VARDE_POSTGRES_PASSWORD=varde
VARDE_POSTGRES_DB=varde

# Redis. Omettre pour activer le mode dégradé (scheduler et rate
# limiting in-memory, pas de pub/sub inter-process, single-process).
VARDE_REDIS_URL=redis://localhost:6379
VARDE_REDIS_PORT=6379

# Keystore (AES-256-GCM, clé 32 octets en base64).
# Générer avec : openssl rand -base64 32
VARDE_KEYSTORE_MASTER_KEY=

# Seed manuel pour le smoke jalon 2 : IDs Discord des serveurs à
# insérer dans la table `guilds` au démarrage de apps/server, séparés
# par des virgules. Bypass temporaire tant que la gateway discord.js
# n'est pas branchée (et donc que GuildCreate n'alimente pas
# automatiquement la table). Format : VARDE_SEED_GUILD_IDS="123,456".
VARDE_SEED_GUILD_IDS=
