# Variables d'environnement de Varde.
#
# Copie ce fichier en `.env.local` à la racine du repo et renseigne
# chaque valeur. Ne committe jamais `.env.local` — il contient des
# secrets. Toute variable obligatoire manquante au démarrage fait
# échouer le boot avec un message explicite.
#
# Lecture :
# - `apps/server` (bot + API en un seul process) lit `.env.local` via
#   `node --env-file=.env.local dist/bin.js`. Voir
#   `apps/server/src/bin.ts` pour la liste exacte.
# - `apps/dashboard` (Next.js) charge automatiquement `.env.local`
#   depuis `apps/dashboard/`. Tu peux symlinker vers le `.env.local`
#   de la racine ou dupliquer.
# - `docker/docker-compose.dev.yml` lit les `VARDE_POSTGRES_*` et
#   `VARDE_REDIS_*` pour le port-mapping et l'init de la base.

# ---------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------

# Niveau de logs Pino. Valeurs possibles : trace | debug | info | warn
# | error | fatal. En prod : `info`. En debug : `debug`.
VARDE_LOG_LEVEL=debug

# ---------------------------------------------------------------------
# Discord — application créée dans le Developer Portal
# ---------------------------------------------------------------------

# Token bot. Onglet « Bot » du Developer Portal. **Obligatoire**.
# Jamais committé, jamais loggé.
VARDE_DISCORD_TOKEN=

# OAuth2 client. Onglet « OAuth2 » du Developer Portal.
# **Obligatoires** côté dashboard pour le login.
VARDE_DISCORD_CLIENT_ID=
VARDE_DISCORD_CLIENT_SECRET=

# ---------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------

# URL publique via laquelle les utilisateurs accèdent au dashboard.
# Utilisée pour la redirection OAuth2 et pour la config CORS de l'API.
# **Optionnelle** : si vide, valeur par défaut `http://localhost:3000`.
# En LAN ou prod : indiquer l'URL effective (`http://192.168.x.x:3000`,
# `https://votre-domaine.com`).
VARDE_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------
# API HTTP (Fastify, exposée par apps/server)
# ---------------------------------------------------------------------

# Port et host d'écoute de l'API. En prod derrière un reverse-proxy
# (Caddy, Traefik, Nginx) on garde 127.0.0.1 et on expose le proxy.
VARDE_API_PORT=4000
VARDE_API_HOST=127.0.0.1

# URL de l'API consommée par le dashboard côté server-component
# (forward de cookie). Doit pointer vers l'API de la même instance.
VARDE_API_URL=http://localhost:4000

# ---------------------------------------------------------------------
# Sessions et keystore
# ---------------------------------------------------------------------

# Secret de session HS256 partagé par Auth.js (dashboard) et le JWT
# authenticator (API). 32 octets aléatoires minimum.
# Générer : `openssl rand -base64 32`
# **Obligatoire**.
VARDE_AUTH_SECRET=

# Master key du keystore (AES-256-GCM). 32 octets en base64.
# Chiffre les secrets stockés en DB (clés API IA notamment).
# Générer : `openssl rand -base64 32`
# **Obligatoire**.
VARDE_KEYSTORE_MASTER_KEY=

# Master key précédente, utilisée uniquement pendant une rotation de
# clé. Procédure complète dans SECURITY.md (« Rotation de la master
# key »). Laisse vide en fonctionnement normal.
VARDE_KEYSTORE_PREVIOUS_MASTER_KEY=

# ---------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------

# URL de connexion lue par apps/server. **Obligatoire**.
# Format Postgres standard. Adapter le host pour pointer vers le
# conteneur Postgres en compose prod.
VARDE_DATABASE_URL=postgres://varde:varde@localhost:5432/varde

# Variables consommées par docker-compose.dev.yml uniquement (init
# de la base et port-mapping). N'a pas d'effet sans Compose.
VARDE_POSTGRES_PORT=5432
VARDE_POSTGRES_USER=varde
VARDE_POSTGRES_PASSWORD=varde
VARDE_POSTGRES_DB=varde

# ---------------------------------------------------------------------
# Redis (optionnel)
# ---------------------------------------------------------------------

# Redis sert au scheduler (BullMQ), au rate limiting partagé et à la
# pub/sub inter-process. Sans Redis, Varde tourne en mode dégradé
# (in-memory, single-process) — voir ADR 0003.
# Variables consommées par docker-compose.dev.yml uniquement.
VARDE_REDIS_PORT=6379

# ---------------------------------------------------------------------
# Stockage des uploads (cartes welcome, polices custom, etc.)
# ---------------------------------------------------------------------

# Dossier où apps/server écrit et lit les images uploadées (cartes
# d'accueil) et les polices custom. Chemin relatif au cwd du process
# ou absolu. En prod : monter un volume persistant ici.
# Défaut : ./uploads
VARDE_UPLOADS_DIR=./uploads

# ---------------------------------------------------------------------
# Seed manuel (jalons de transition)
# ---------------------------------------------------------------------

# IDs Discord des serveurs à insérer dans la table `guilds` au boot,
# séparés par des virgules. Utile uniquement quand le bot n'a pas
# encore reçu d'événement `GuildCreate` après une réinstallation.
# Format : VARDE_SEED_GUILD_IDS="123456789012345678,234567890123456789"
VARDE_SEED_GUILD_IDS=
