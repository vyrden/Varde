{
  "name": "varde",
  "private": true,
  "version": "0.0.0",
  "description": "Bot Discord auto-hébergé, pensé comme plateforme d'extensions.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint typecheck test",
    "db:generate": "pnpm --filter @varde/db db:generate:pg && pnpm --filter @varde/db db:generate:sqlite",
    "db:migrate": "pnpm --filter @varde/db db:migrate:pg"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "24.12.2",
    "@varde/config": "workspace:*",
    "turbo": "2.9.6",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "esbuild@<0.25.0": ">=0.25.0",
      "uuid@<11.1.0": ">=11.1.0",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
