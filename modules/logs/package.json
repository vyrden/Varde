    "test:integration": "vitest run tests/integration",
    "dev": "tsc --watch --preserveWatchOutput"
  },
  "dependencies": {
    "@varde/contracts": "workspace:*",
    "@varde/core": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@varde/config": "workspace:*",
    "@varde/db": "workspace:*",
    "@varde/testing": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
