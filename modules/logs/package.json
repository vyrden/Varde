{
  "name": "@varde/module-logs",
  "private": true,
  "version": "1.1.0",
  "description": "Module officiel : dispatch des événements guild.* vers des salons Discord configurables.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
