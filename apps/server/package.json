{
  "name": "@varde/server",
  "private": true,
  "version": "0.0.0",
  "description": "Entrée monolith : bot Discord + API HTTP dans un même process Node (ADR 0004).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=../../.env.local dist/bin.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "dev": "tsc && node --watch --env-file=../../.env.local dist/bin.js"
  },
  "dependencies": {
    "@varde/api": "workspace:*",
    "@varde/bot": "workspace:*",
    "@varde/contracts": "workspace:*",
    "@varde/core": "workspace:*",
    "@varde/db": "workspace:*",
    "@varde/module-hello-world": "workspace:*",
    "@varde/module-logs": "workspace:*",
    "@varde/module-moderation": "workspace:*",
    "@varde/module-reaction-roles": "workspace:*",
    "@varde/module-welcome": "workspace:*",
    "@varde/presets": "workspace:*",
    "discord.js": "14.26.3"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@varde/config": "workspace:*",
    "better-sqlite3": "12.9.0",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
