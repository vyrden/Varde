{
  "name": "@varde/db",
  "private": true,
  "version": "0.0.0",
  "description": "Schémas Drizzle, migrations, client DB.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "db:generate:pg": "drizzle-kit generate --config=drizzle.pg.config.ts",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle.sqlite.config.ts",
    "db:migrate:pg": "tsx --env-file-if-exists=../../.env.local scripts/migrate.ts pg",
    "db:migrate:sqlite": "tsx --env-file-if-exists=../../.env.local scripts/migrate.ts sqlite"
  },
  "dependencies": {
    "@varde/contracts": "workspace:*",
    "better-sqlite3": "12.9.0",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.9",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "11.14.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.12.2",
    "@varde/config": "workspace:*",
    "drizzle-kit": "0.31.10",
    "testcontainers": "11.14.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
